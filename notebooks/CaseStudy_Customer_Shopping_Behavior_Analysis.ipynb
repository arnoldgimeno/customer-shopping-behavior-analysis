   "id": "2244b482-4b2e-460d-8403-dca4a3583f73",
   "metadata": {},
   "outputs": [],
   "source": [
    "def apply_dark_theme(fig, title):\n",
    "    fig.update_layout(\n",
    "        title={\n",
    "            \"text\": title,\n",
    "            \"x\": 0.05,\n",
    "            \"xanchor\": \"left\",\n",
    "            \"font\": {\"size\": 22, \"color\": \"white\"}\n",
    "        },\n",
    "        paper_bgcolor=\"#0b0f19\",\n",
    "        plot_bgcolor=\"#0b0f19\",\n",
    "        font={\"family\": \"Arial\", \"color\": \"white\", \"size\": 13},\n",
    "        xaxis=dict(\n",
    "            showgrid=True,\n",
    "            gridcolor=\"#22304a\",\n",
    "            zeroline=False,\n",
    "            showline=False\n",
    "        ),\n",
    "        yaxis=dict(\n",
    "            showgrid=True,\n",
    "            gridcolor=\"#22304a\",\n",
    "            zeroline=False,\n",
    "            showline=False\n",
    "        ),\n",
    "        margin=dict(l=60, r=40, t=70, b=60),\n",
    "        height=600,\n",
    "        width=1000\n",
    "    )\n",
    "    return fig"
   ]
