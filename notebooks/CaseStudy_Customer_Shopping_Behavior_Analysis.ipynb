    "            color=scatter_df[\"review_rating\"],\n",
    "            colorscale=\"Purples\",\n",
    "            showscale=True,\n",
    "            colorbar=dict(title=\"Review Rating\")\n",
    "        ),\n",
    "        text=scatter_df[\"category\"],\n",
    "        hovertemplate=(\n",
    "            \"<b>Category:</b> %{text}<br>\"\n",
    "            \"<b>Previous Purchases:</b> %{x}<br>\"\n",
    "            \"<b>Purchase Amount:</b> $%{y:.2f}<extra></extra>\"\n",
    "        )\n",
    "    ),\n",
    "    row=3, col=2\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 13. TOP 10 ITEMS BY REVENUE\n",
    "# =========================\n",
    "fig.add_trace(\n",
    "    go.Bar(\n",
    "        x=top_items[\"purchase_amount\"],\n",
    "        y=top_items[\"item_purchased\"],\n",
    "        orientation=\"h\",\n",
    "        marker_color=bar_color,\n",
    "        text=[f\"${v:,.0f}\" for v in top_items[\"purchase_amount\"]],\n",
    "        textposition=\"outside\",\n",
    "        hovertemplate=\"<b>%{y}</b><br>Revenue: $%{x:,.2f}<extra></extra>\"\n",
    "    ),\n",
    "    row=3, col=3\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 14. LAYOUT STYLING\n",
    "# =========================\n",
    "fig.update_layout(\n",
    "    title={\n",
    "        \"text\": \"<b>Customer Shopping Behavior Dashboard</b>\",\n",
    "        \"x\": 0.5,\n",
    "        \"xanchor\": \"center\",\n",
    "        \"font\": {\"size\": 34, \"color\": title_color}\n",
    "    },\n",
    "    paper_bgcolor=bg_color,\n",
    "    plot_bgcolor=panel_color,\n",
    "    font=dict(family=\"Arial, sans-serif\", size=12, color=\"#444\"),\n",
    "    height=1100,\n",
    "    width=1600,\n",
    "    margin=dict(l=60, r=60, t=100, b=60),\n",
    "    showlegend=False\n",
    ")\n",
    "\n",
    "# Make subplot titles purple\n",
    "for ann in fig[\"layout\"][\"annotations\"]:\n",
    "    ann[\"font\"] = dict(size=16, color=accent)\n",
    "\n",
    "# Grid and axis styling\n",
    "fig.update_xaxes(showgrid=True, gridcolor=grid_color, zeroline=False)\n",
    "fig.update_yaxes(showgrid=True, gridcolor=grid_color, zeroline=False)\n",
