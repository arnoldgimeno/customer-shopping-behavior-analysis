  {
   "cell_type": "markdown",
   "id": "18d1ec7e-015d-462a-8d88-a63a34dd3c11",
   "metadata": {},
   "source": [
    "## Connecting Python script to PostgreSQL"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b5e91c8e-dbcc-497b-a95e-406d354bbc80",
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install psycopg2-binary sqlalchemy\n",
    "# install \"psycopg2-binary\" and \"sqlalchemy\" to connect Python to PostgreSQL."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "971e06b4-be0e-4dd5-8f38-42f7241a0fc3",
   "metadata": {},
   "source": [
    "## Code for MS SQL Server"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3d88a3eb-0ebc-40d1-99c9-9d58d9af1007",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "from sqlalchemy import create_engine\n",
    "\n",
    "# Step 1 : Connect to PostgreSQL\n",
    "# Credentials are read from environment variables rather than hardcoded,\n",
    "# so this notebook can be shared/committed safely. Set these in your shell\n",
    "# or a local .env file before running this cell:\n",
    "#   export PG_USER=postgres\n",
    "#   export PG_PASSWORD=your_password_here\n",
    "#   export PG_HOST=localhost\n",
    "#   export PG_PORT=5432\n",
    "#   export PG_DATABASE=customer_behavior\n",
    "username = os.environ.get(\"PG_USER\", \"postgres\")\n",
    "password = os.environ.get(\"PG_PASSWORD\", \"\")\n",
    "host = os.environ.get(\"PG_HOST\", \"localhost\")\n",
    "port = os.environ.get(\"PG_PORT\", \"5432\")\n",
    "database = os.environ.get(\"PG_DATABASE\", \"customer_behavior\")\n",
    "\n",
    "engine = create_engine(f\"postgresql+psycopg2://{username}:{password}@{host}:{port}/{database}\")\n",
    "\n",
    "# Step 2 : Load DataFrame into PostgreSQL\n",
    "table_name = \"customer\"  # table name you created in pgAdmin under DATABASE named \"customer_behavior\"\n",
    "df.to_sql(table_name, engine, if_exists=\"replace\", index=False)\n",
    "\n",
    "print(f\"Data successfully loaded into table '{table_name}' in database '{database}'.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "da824815-42ea-4e24-9606-77c7adad7426",
   "metadata": {},
   "source": [
    "## Building Dashboard using Plotly"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eb03080a-9417-4f4b-ac1c-9a639badc049",
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install dash plotly pandas numpy"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a805a828-6638-4fe6-a98d-b418ea888b5b",
   "metadata": {},
   "source": [
    "## Create interactive dashboard using Plotly. Note: Power BI has been embeded on the website, therefore, this one is no longer necessary to upload on the website."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "81a7aaac-fc16-423d-bcb3-879cbbb39a53",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import plotly.graph_objects as go\n",
    "from plotly.subplots import make_subplots\n",
    "\n",
    "# =========================\n",
    "# 1. LOAD CLEANED DATA\n",
    "# =========================\n",
    "df = pd.read_csv(CLEANED_DATA_PATH)\n",
    "\n",
    "# =========================\n",
    "# 2. BASIC CHECK\n",
    "# =========================\n",
    "df.columns = df.columns.str.strip()\n",
    "\n",
    "# Optional: make text columns neat\n",
    "text_cols = [\n",
    "    \"gender\", \"item_purchased\", \"category\", \"location\", \"size\", \"color\",\n",
    "    \"season\", \"subscription_status\", \"shipping_type\",\n",
    "    \"discount_applied\", \"payment_method\", \"frequency_of_purchases\",\n",
    "    \"age_group\"\n",
    "]\n",
    "\n",
    "for col in text_cols:\n",
    "    if col in df.columns:\n",
    "        df[col] = df[col].astype(str).str.strip().str.title()\n",
    "\n",
    "# =========================\n",
    "# 3. KPI CALCULATIONS\n",
    "# =========================\n",
    "total_revenue = df[\"purchase_amount\"].sum()\n",
    "customer_count = df[\"customer_id\"].nunique()\n",
    "avg_purchase = df[\"purchase_amount\"].mean()\n",
    "avg_rating = df[\"review_rating\"].mean()\n",
    "\n",
    "# =========================\n",
    "# 4. SUMMARY TABLES\n",
    "# =========================\n",
    "\n",
    "# Revenue by category\n",
    "revenue_by_category = (\n",
    "    df.groupby(\"category\", as_index=False)[\"purchase_amount\"]\n",
    "    .sum()\n",
    "    .sort_values(\"purchase_amount\", ascending=False)\n",
    ")\n",
    "\n",
    "# Customer share by subscription\n",
    "subscription_share = (\n",
    "    df.groupby(\"subscription_status\")\n",
    "    .size()\n",
    "    .reset_index(name=\"count\")\n",
    ")\n",
    "\n",
    "# Revenue by age group\n",
    "age_order = [\"Young Adult\", \"Adult\", \"Middle-Aged\", \"Senior\"]\n",
    "revenue_by_age = (\n",
    "    df.groupby(\"age_group\", as_index=False)[\"purchase_amount\"]\n",
    "    .sum()\n",
    ")\n",
    "revenue_by_age[\"age_group\"] = pd.Categorical(\n",
    "    revenue_by_age[\"age_group\"],\n",
    "    categories=age_order,\n",
    "    ordered=True\n",
    ")\n",
    "revenue_by_age = revenue_by_age.sort_values(\"age_group\")\n",
    "\n",
    "# Average purchase by shipping type\n",
    "avg_purchase_by_shipping = (\n",
    "    df.groupby(\"shipping_type\", as_index=False)[\"purchase_amount\"]\n",
    "    .mean()\n",
    "    .sort_values(\"purchase_amount\", ascending=False)\n",
    ")\n",
    "\n",
    "# Top 10 items by revenue\n",
    "top_items = (\n",
    "    df.groupby(\"item_purchased\", as_index=False)[\"purchase_amount\"]\n",
    "    .sum()\n",
    "    .sort_values(\"purchase_amount\", ascending=False)\n",
    "    .head(10)\n",
    ")\n",
    "top_items = top_items.sort_values(\"purchase_amount\", ascending=True)\n",
    "\n",
    "# Scatter data\n",
    "scatter_df = df.copy()\n",
    "\n",
    "# =========================\n",
    "# 5. COLORS\n",
    "# =========================\n",
    "bg_color = \"#f5f5f5\"\n",
    "panel_color = \"#ffffff\"\n",
    "title_color = \"#1f1f1f\"\n",
    "accent = \"#7a1fa2\"\n",
    "bar_color = \"#311b92\"\n",
    "pink = \"#c060b6\"\n",
    "grid_color = \"#dddddd\"\n",
    "\n",
    "# =========================\n",
    "# 6. CREATE SUBPLOTS\n",
    "# =========================\n",
    "fig = make_subplots(\n",
    "    rows=3,\n",
    "    cols=3,\n",
    "    specs=[\n",
    "        [{\"type\": \"indicator\"}, {\"type\": \"indicator\"}, {\"type\": \"indicator\"}],\n",
    "        [{\"type\": \"domain\"}, {\"type\": \"xy\"}, {\"type\": \"xy\"}],\n",
    "        [{\"type\": \"xy\"}, {\"type\": \"xy\"}, {\"type\": \"xy\"}]\n",
    "    ],\n",
    "    subplot_titles=(\n",
    "        \"\", \"\", \"\",\n",
    "        \"Customer Share by Subscription Status\",\n",
    "        \"Revenue by Category\",\n",
    "        \"Revenue by Age Group\",\n",
    "        \"Average Purchase Amount by Shipping Type\",\n",
    "        \"Previous Purchases vs Purchase Amount\",\n",
    "        \"Top 10 Items by Revenue\"\n",
    "    ),\n",
    "    vertical_spacing=0.12,\n",
    "    horizontal_spacing=0.08\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 7. KPI CARDS\n",
    "# =========================\n",
    "fig.add_trace(\n",
    "    go.Indicator(\n",
    "        mode=\"number\",\n",
    "        value=total_revenue,\n",
    "        number={\"prefix\": \"$\", \"valueformat\": \",.0f\", \"font\": {\"size\": 42, \"color\": accent}},\n",
    "        title={\"text\": \"<b>Total Revenue</b>\", \"font\": {\"size\": 20, \"color\": \"#555\"}}\n",
    "    ),\n",
    "    row=1, col=1\n",
    ")\n",
    "\n",
    "fig.add_trace(\n",
    "    go.Indicator(\n",
    "        mode=\"number\",\n",
    "        value=customer_count,\n",
    "        number={\"valueformat\": \",\", \"font\": {\"size\": 42, \"color\": accent}},\n",
    "        title={\"text\": \"<b>Customer Count</b>\", \"font\": {\"size\": 20, \"color\": \"#555\"}}\n",
    "    ),\n",
    "    row=1, col=2\n",
    ")\n",
    "\n",
    "fig.add_trace(\n",
    "    go.Indicator(\n",
    "        mode=\"number\",\n",
    "        value=avg_purchase,\n",
    "        number={\"prefix\": \"$\", \"valueformat\": \".2f\", \"font\": {\"size\": 42, \"color\": accent}},\n",
    "        title={\"text\": \"<b>Average Purchase Amount</b>\", \"font\": {\"size\": 20, \"color\": \"#555\"}}\n",
    "    ),\n",
    "    row=1, col=3\n",
    ")\n",
    "\n",
    "# Add avg rating as annotation-style KPI in top row right side overlay\n",
    "fig.add_annotation(\n",
    "    x=0.97, y=1.02,\n",
    "    xref=\"paper\", yref=\"paper\",\n",
    "    text=f\"<span style='font-size:42px;color:{accent};'><b>{avg_rating:.2f}</b></span><br><span style='font-size:20px;color:#555;'><b>Average Review Rating</b></span>\",\n",
    "    showarrow=False,\n",
    "    align=\"center\"\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 8. DONUT CHART\n",
    "# =========================\n",
    "fig.add_trace(\n",
    "    go.Pie(\n",
    "        labels=subscription_share[\"subscription_status\"],\n",
    "        values=subscription_share[\"count\"],\n",
    "        hole=0.6,\n",
    "        marker=dict(colors=[bar_color, pink]),\n",
    "        textinfo=\"label+percent\",\n",
    "        showlegend=False\n",
    "    ),\n",
    "    row=2, col=1\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 9. REVENUE BY CATEGORY\n",
    "# =========================\n",
    "fig.add_trace(\n",
    "    go.Bar(\n",
    "        x=revenue_by_category[\"category\"],\n",
    "        y=revenue_by_category[\"purchase_amount\"],\n",
    "        marker_color=bar_color,\n",
    "        text=[f\"${v:,.0f}\" for v in revenue_by_category[\"purchase_amount\"]],\n",
    "        textposition=\"outside\",\n",
    "        hovertemplate=\"<b>%{x}</b><br>Revenue: $%{y:,.2f}<extra></extra>\"\n",
    "    ),\n",
    "    row=2, col=2\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 10. REVENUE BY AGE GROUP\n",
    "# =========================\n",
    "fig.add_trace(\n",
    "    go.Bar(\n",
    "        x=revenue_by_age[\"age_group\"],\n",
    "        y=revenue_by_age[\"purchase_amount\"],\n",
    "        marker_color=bar_color,\n",
    "        text=[f\"${v:,.0f}\" for v in revenue_by_age[\"purchase_amount\"]],\n",
    "        textposition=\"outside\",\n",
    "        hovertemplate=\"<b>%{x}</b><br>Revenue: $%{y:,.2f}<extra></extra>\"\n",
    "    ),\n",
    "    row=2, col=3\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 11. AVG PURCHASE BY SHIPPING TYPE\n",
    "# =========================\n",
    "fig.add_trace(\n",
    "    go.Bar(\n",
    "        x=avg_purchase_by_shipping[\"shipping_type\"],\n",
    "        y=avg_purchase_by_shipping[\"purchase_amount\"],\n",
    "        marker_color=bar_color,\n",
    "        text=[f\"${v:.2f}\" for v in avg_purchase_by_shipping[\"purchase_amount\"]],\n",
    "        textposition=\"outside\",\n",
    "        hovertemplate=\"<b>%{x}</b><br>Avg Purchase: $%{y:,.2f}<extra></extra>\"\n",
    "    ),\n",
    "    row=3, col=1\n",
    ")\n",
    "\n",
    "# =========================\n",
    "# 12. SCATTER PLOT\n",
    "# =========================\n",
    "fig.add_trace(\n",
    "    go.Scatter(\n",
    "        x=scatter_df[\"previous_purchases\"],\n",
    "        y=scatter_df[\"purchase_amount\"],\n",
