   "id": "5296428e-804a-4715-b8c2-7fe432005551",
   "metadata": {},
   "outputs": [],
   "source": [
    "(df[\"discount_applied\"]==df[\"promo_code_used\"]).all()\n",
    "# check if ALL \"discount applied\" USED \"promo code\"."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d8230224-261e-4a96-bff7-e7b89416b46c",
   "metadata": {},
   "source": [
    "## Remove \"promo_code_used\" column"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "743badcd-3cca-40cc-8213-f529681dbcab",
   "metadata": {},
   "outputs": [],
   "source": [
    "df=df.drop(\"promo_code_used\", axis=1)\n",
    "# remove \"promo_code_used\" column. \"axis=1\" (=0 is horizontal (row), =1 is vertical (column))"
   ]
  },
