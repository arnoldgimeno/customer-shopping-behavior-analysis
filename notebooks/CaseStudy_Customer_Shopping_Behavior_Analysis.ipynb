 "cells": [
  {
   "cell_type": "markdown",
   "id": "setup-md-0001",
   "metadata": {},
   "source": [
    "### Project setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "setup-code-0001",
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "# Resolve the project root whether this notebook is run from the repo\n",
    "# root or from inside the notebooks/ folder (portable across machines).\n",
    "PROJECT_PATH = Path.cwd().parent if Path.cwd().name == \"notebooks\" else Path.cwd()\n",
    "PROJECT_PATH = str(PROJECT_PATH)\n",
    "\n",
    "if PROJECT_PATH not in sys.path:\n",
    "    sys.path.append(PROJECT_PATH)\n",
    "\n",
    "RAW_DATA_PATH = Path(PROJECT_PATH) / \"data\" / \"incoming\" / \"customer_shopping_behavior_rawfile.csv\"\n",
    "PROCESSED_DIR = Path(PROJECT_PATH) / \"data\" / \"processed\"\n",
    "PROCESSED_DIR.mkdir(parents=True, exist_ok=True)\n",
    "CLEANED_DATA_PATH = PROCESSED_DIR / \"customer_shopping_behavior_cleaned.csv\"\n",
    "\n",
    "print(\"Project path:\", PROJECT_PATH)",
    "\n",
    "CHARTS_DIR = Path(PROJECT_PATH) / \"charts\"\n",
    "CHARTS_DIR.mkdir(parents=True, exist_ok=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "00a56839-b87d-44f3-bf57-8eb6d06357e6",
   "metadata": {},
   "source": [
    "## Import Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6f31f6d1-a1e4-427f-9b3b-2a16aba93c29",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import sys\n",
    "\n",
    "df = pd.read_csv(RAW_DATA_PATH)"
   ]
  },
