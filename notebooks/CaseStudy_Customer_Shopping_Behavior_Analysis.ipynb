   "id": "506c59a7-4542-45db-a288-396f1708919d",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.isnull().sum()\n",
    "# identify the number of null values in entire table.\n",
    "# NaN (\"Not a Number\") represents missing or undefined numeric data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "76124a50-59a8-44a3-90a6-2c1b356c9e0d",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[\"Review Rating\"] = df.groupby(\"Category\")[\"Review Rating\"].transform(lambda x: x.fillna(x.median()))\n",
    "# It fills missing review ratings (NaN) \n",
    "# using the median rating of each category, \n",
    "# while keeping the original DataFrame shape unchanged."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0c332864-f19a-4d63-b1c8-34465df9f66e",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.isnull().sum()\n",
    "# check if NA values under Review Rating are fixed."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bbbdd382-7e69-4264-919f-c83e0cb609fe",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.columns = df.columns.str.lower()\n",
    "df.columns = df.columns.str.replace(\" \",\"_\")\n",
    "# properly rename all column names using \"snake_case\" naming convention."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "14f1af42-68a2-4c14-864b-dd7f87b4355b",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.columns\n",
    "# check if \"snake_case\" was applied."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f4cd572f-daba-4933-ad56-e55255236e23",
   "metadata": {},
   "source": [
    "## Rename column"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d2557c93-07c2-4250-ad59-d3afa3dd2c50",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = df.rename(columns = {\"purchase_amount_(usd)\":\"purchase_amount\"})\n",
    "# rename a column by removing _(usd) which is not needed."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0da29add-6a49-42cf-9351-37a2934314a7",
   "metadata": {},
   "outputs": [],
   "source": [
    "df.columns\n",
    "# check if column was renamed to \"purchase_amount\". "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c9f819ed-e172-4f6f-aac0-bb2e9bbf1a21",
   "metadata": {},
   "source": [
    "## Create a column age group"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "21c989d8-0007-472a-9116-afea3b155413",
   "metadata": {},
   "outputs": [],
   "source": [
    "# create a column age_group\n",
    "labels = [\"Young Adult\", \"Adult\", \"Middle-Aged\", \"Senior\"]\n",
    "df[\"age_group\"] = pd.qcut(df[\"age\"], q=4, labels=labels, duplicates=\"drop\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e12f79af-9f62-49fa-a03c-991a4e2b5fe1",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[[\"age\", \"age_group\"]].head(10) # check the first 10 rows."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ac157bb1-1ce9-4643-8483-0a2daa9935d1",
   "metadata": {},
   "source": [
    "## Create column purchase frequency days"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4bc9d224-dac1-453d-ae6b-7d90d99ca9a3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# create column purchase_frequency_days\n",
    "frequency_mapping = {\n",
    "    \"Fortnightly\": 14,\n",
    "    \"Weekly\": 7,\n",
    "    \"Monthly\": 30,\n",
    "    \"Quarterly\": 90,\n",
    "    \"Bi-Weekly\": 14, \n",
    "    \"Annually\": 365,\n",
    "    \"Every 3 Months\": 90\n",
    "}\n",
    "df[\"purchase_frequency_days\"] = df[\"frequency_of_purchases\"].map(frequency_mapping)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d8bad2f1-d0b6-4b36-8d25-99f483ee80e6",
   "metadata": {},
   "outputs": [],
   "source": [
    "df[[\"purchase_frequency_days\", \"frequency_of_purchases\"]].head(10)\n",
    "# check if \"frequency_of_purchases\" column was created."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "971c4204-385a-4757-8523-0ec2dc14010e",
   "metadata": {},
   "source": [
