 "source": [
  "## Pareto analysis (80/20 rule)\n",
  "\n",
  "Tests whether a small share of items drives most of the revenue, the way the 80/20 rule\n",
  "would predict. Items are ranked by total revenue, then plotted against their cumulative\n",
  "share of total revenue."
 ],
 "id": "pareto-md-0001"
},
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
  "import plotly.graph_objects as go\n",
  "\n",
  "revenue_by_item = (\n",
  "    df.groupby(\"item_purchased\", as_index=False)[\"purchase_amount\"]\n",
  "    .sum()\n",
  "    .sort_values(\"purchase_amount\", ascending=False)\n",
  "    .reset_index(drop=True)\n",
  ")\n",
  "revenue_by_item[\"cum_pct\"] = revenue_by_item[\"purchase_amount\"].cumsum() / revenue_by_item[\"purchase_amount\"].sum() * 100\n",
  "\n",
  "n_items = len(revenue_by_item)\n",
  "n_top20 = round(n_items * 0.2)\n",
  "pct_rev_top20 = revenue_by_item[\"purchase_amount\"].iloc[:n_top20].sum() / revenue_by_item[\"purchase_amount\"].sum() * 100\n",
  "n_for_80 = (revenue_by_item[\"cum_pct\"] <= 80).sum() + 1\n",
  "print(f\"Top 20% of items ({n_top20} of {n_items}) generate {pct_rev_top20:.1f}% of revenue\")\n",
  "print(f\"{n_for_80} of {n_items} items ({n_for_80 / n_items * 100:.1f}%) are needed to reach 80% of revenue\")\n",
  "\n",
  "fig = go.Figure()\n",
  "fig.add_trace(go.Bar(\n",
  "    x=revenue_by_item[\"item_purchased\"],\n",
  "    y=revenue_by_item[\"purchase_amount\"],\n",
  "    name=\"Revenue (USD)\",\n",
  "    marker_color=\"#5B8FF9\"\n",
  "))\n",
  "fig.add_trace(go.Scatter(\n",
  "    x=revenue_by_item[\"item_purchased\"],\n",
  "    y=revenue_by_item[\"cum_pct\"],\n",
  "    name=\"Cumulative % of revenue\",\n",
  "    yaxis=\"y2\",\n",
  "    mode=\"lines+markers\",\n",
  "    line=dict(color=\"#F6BD16\", width=2)\n",
  "))\n",
  "fig.add_hline(y=80, line_dash=\"dash\", line_color=\"#61DDAA\", yref=\"y2\")\n",
  "\n",
  "apply_dark_theme(fig, \"Pareto Analysis \u2014 Revenue by Item Purchased\")\n",
  "fig.update_layout(\n",
  "    yaxis=dict(title=\"Revenue (USD)\", showgrid=True, gridcolor=\"#22304a\"),\n",
  "    yaxis2=dict(title=\"Cumulative % of revenue\", overlaying=\"y\", side=\"right\", range=[0, 100]),\n",
  "    xaxis=dict(tickangle=-45)\n",
  ")\n",
  "\n",
  "fig.write_html(CHARTS_DIR / \"pareto_revenue_by_item_dark.html\", include_plotlyjs=True,\n",
